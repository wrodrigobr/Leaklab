{
  "_metadata": {
    "projeto": "LeakLab",
    "versao": "1.0.0",
    "descricao": "Ranges GTO preflop consolidados para MTT 8-max com ante de 1bb (12.5%). Dados cruzados e validados entre RangeConverter, PokerCoaching e Reg Life.",
    "formato": "MTT 8-max com ante de 1bb",
    "fontes": [
      "RangeConverter.com - 8max MTT GTO Ranges (resolvidas sem limp)",
      "PokerCoaching.com - MTT Preflop Charts GTO + Push/Fold",
      "Reg Life - 216 Ranges Preflop (RFI e vs RFI)"
    ],
    "analise_coerencia": {
      "conclusao": "As três fontes apresentam alta coerência entre si. As pequenas divergências ocorrem nas mãos marginais das bordas de range (±2-3% de frequência) e são esperadas dado que cada fonte usa simplificações diferentes das estratégias mistas dos solvers. Onde as fontes divergem, foi usada a mediana como valor de referência.",
      "nivel_confianca": {
        "10bb": "alto - todas as fontes concordam nas mãos principais",
        "20bb": "alto - convergência forte em RFI e vs RFI",
        "30bb": "alto - base sólida com pequenas variações nas mãos marginais",
        "40bb": "médio-alto - Reg Life não cobre este stack explicitamente, interpolado entre 30bb e 50bb",
        "50bb": "alto - boa coerência entre RangeConverter e Reg Life",
        "75bb": "médio - baseado principalmente no PokerCoaching, validado com RangeConverter 60bb+100bb",
        "100bb": "alto - todas as fontes cobrem este stack"
      },
      "divergencias_notaveis": [
        "SB a 75bb+: PokerCoaching inclui opção de limp em 81.6% das mãos, RangeConverter sugere range de raise mais restrito. LeakLab usa raise range conservador.",
        "BTN a 10bb: PokerCoaching sugere 38.9%, RangeConverter ligeiramente maior. Adotado valor médio.",
        "UTG a 30bb: Reg Life é mais conservadora (18-20%) vs PokerCoaching (23.5% no LJ equivalente). Ajuste feito por posição."
      ]
    },
    "como_usar": {
      "stack_bucket": "Use a funcao get_stack_bucket() para mapear o stack efetivo do jogador para o bucket correto",
      "tolerancia_leak": "Desvio de +/- 5% do RFI_pct é considerado aceitável. Acima disso, flagrar como leak.",
      "posicoes": "UTG=Under The Gun, UTG1=UTG+1, LJ=LoJack/MP, HJ=HiJack, CO=Cutoff, BTN=Button, SB=Small Blind, BB=Big Blind",
      "acoes": "RFI=Raise First In, CALL=Flat Call, FOLD=Fold, ALLIN=All-In direto, THREBET=Re-raise/3bet"
    }
  },

