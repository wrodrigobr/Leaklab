# ── LeakLabs backend ────────────────────────────────────────────────
LEAKLAB_URL=http://localhost:5000
LEAKLAB_ADMIN_TOKEN=cole_aqui_seu_token_admin

# ── GTO Wizard credentials ──────────────────────────────────────────
GTW_EMAIL=seu_email@exemplo.com
GTW_PASSWORD=sua_senha

# ── Bot config ──────────────────────────────────────────────────────
BATCH_SIZE=100          # nós por POST ao backend
DELAY_MS=800            # pausa entre requests (ms) — respeitar rate limit
HEADLESS=false          # false = browser visível, true = background
