[Unit]
Description=LeakLab GTO Solver API
After=network.target

[Service]
Type=simple
User=leaklab
WorkingDirectory=/opt/leaklab/backend/gto_bot/solver_api
Environment=GTO_API_KEY=CHANGE_ME
Environment=GTO_PORT=8765
Environment=GTO_TIMEOUT=300
ExecStart=/usr/bin/python3 server.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
